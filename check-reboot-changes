#!/usr/bin/env python3
"""
check-reboot-changes
Run at login (add to ~/.bash_profile or /etc/profile.d/reboot-check.sh) to
detect whether the server was rebooted since your last session and show any
hardware changes.

Snapshot stored per-user in ~/.cache/server-reboot-guardian/hw_snapshot.json
A system-wide pre-reboot snapshot (written by server-reboot-guardian before
shutdown) is also consulted when available for a before/after comparison.
"""

import json
import os
import pwd
import socket
import subprocess
import sys
from collections import defaultdict
from datetime import datetime
from pathlib import Path

SYSTEM_PRE_REBOOT_SNAPSHOT = Path("/var/lib/server-reboot-guardian/pre_reboot_snapshot.json")
SNAPSHOT_DIR  = Path.home() / ".cache" / "server-reboot-guardian"
SNAPSHOT_FILE = SNAPSHOT_DIR / "hw_snapshot.json"


# ---------------------------------------------------------------------------
# Boot / login time helpers
# ---------------------------------------------------------------------------

def get_last_boot_time() -> datetime | None:
    # Prefer 'who -b' (most distros)
    try:
        out = subprocess.run(["who", "-b"], capture_output=True, text=True).stdout
        for line in out.splitlines():
            if "boot" in line:
                parts = line.strip().split()
                return datetime.strptime(f"{parts[-2]} {parts[-1]}", "%Y-%m-%d %H:%M")
    except Exception:
        pass
    # Fallback: /proc/uptime
    try:
        with open("/proc/uptime") as f:
            secs = float(f.read().split()[0])
        return datetime.fromtimestamp(datetime.now().timestamp() - secs)
    except Exception:
        return None


def get_previous_login_time(username: str) -> datetime | None:
    """Return the start time of the login BEFORE the current session."""
    try:
        out = subprocess.run(
            ["last", "-F", "-n", "6", username],
            capture_output=True, text=True,
        ).stdout
        entries = [l for l in out.splitlines() if l.startswith(username)]
        # entries[0] = current session; entries[1] = previous session
        if len(entries) >= 2:
            parts = entries[1].split()
            # layout: user tty host DoW Mon DD HH:MM:SS YYYY ...
            dt_str = " ".join(parts[3:8])
            return datetime.strptime(dt_str, "%a %b %d %H:%M:%S %Y")
    except Exception:
        pass
    return None


# ---------------------------------------------------------------------------
# Hardware snapshot collection (no root required)
# ---------------------------------------------------------------------------

def _run(cmd: list[str], timeout=8) -> str:
    try:
        return subprocess.run(
            cmd, capture_output=True, text=True, timeout=timeout
        ).stdout.strip()
    except Exception:
        return ""


def collect_hardware_snapshot() -> dict:
    snap: dict = {}

    # Kernel
    snap["kernel"] = _run(["uname", "-r"])

    # CPU
    snap["cpu"] = {}
    for line in _run(["lscpu"]).splitlines():
        if ":" in line:
            k, _, v = line.partition(":")
            k = k.strip()
            if k in (
                "Architecture", "CPU(s)", "Model name",
                "Thread(s) per core", "Core(s) per socket", "Socket(s)",
                "NUMA node(s)", "CPU MHz", "CPU max MHz",
            ):
                snap["cpu"][k] = v.strip()

    # Memory (MB totals from /proc/meminfo)
    mem = {}
    try:
        for line in Path("/proc/meminfo").read_text().splitlines():
            k, _, v = line.partition(":")
            k = k.strip()
            if k in ("MemTotal", "SwapTotal"):
                mem[k] = v.strip()
    except Exception:
        pass
    snap["memory"] = mem

    # PCI devices (vendor:device pairs, sorted for stable comparison)
    pci_lines = _run(["lspci", "-mm"]).splitlines()
    snap["pci_devices"] = sorted(pci_lines)

    # Block devices
    try:
        blk_raw = _run(["lsblk", "--json", "-o", "NAME,SIZE,TYPE,MODEL,TRAN"])
        snap["block_devices"] = json.loads(blk_raw) if blk_raw else {}
    except Exception:
        snap["block_devices"] = {}

    # Network interfaces
    try:
        net_raw = _run(["ip", "-j", "link"])
        ifaces = json.loads(net_raw) if net_raw else []
        snap["network_interfaces"] = sorted(
            [{"ifname": i.get("ifname"), "link_type": i.get("link_type"),
              "address": i.get("address")}
             for i in ifaces],
            key=lambda x: x.get("ifname", ""),
        )
    except Exception:
        snap["network_interfaces"] = []

    # DMI / firmware info (readable without root via sysfs)
    dmi = {}
    dmi_sysfs = Path("/sys/class/dmi/id")
    for field in ("bios_version", "bios_date", "board_name",
                  "product_name", "sys_vendor"):
        p = dmi_sysfs / field
        if p.exists():
            try:
                dmi[field] = p.read_text().strip()
            except Exception:
                pass
    snap["dmi"] = dmi

    snap["recorded_at"] = datetime.now().isoformat()
    snap["boot_time"]   = get_last_boot_time().isoformat() if get_last_boot_time() else None

    return snap


# ---------------------------------------------------------------------------
# Diff helpers
# ---------------------------------------------------------------------------

def _diff_dict(label: str, old: dict, new: dict, lines: list[str]):
    all_keys = sorted(set(old) | set(new))
    for k in all_keys:
        o, n = old.get(k), new.get(k)
        if o != n:
            if o is None:
                lines.append(f"  + {label} / {k}: {n}")
            elif n is None:
                lines.append(f"  - {label} / {k}: {o}")
            else:
                lines.append(f"  ~ {label} / {k}:  {o}  →  {n}")


def _diff_sorted_list(label: str, old: list, new: list, lines: list[str]):
    removed = [x for x in old if x not in new]
    added   = [x for x in new if x not in old]
    for x in removed:
        lines.append(f"  - {label}: {x}")
    for x in added:
        lines.append(f"  + {label}: {x}")


def _diff_iface_list(old: list, new: list, lines: list[str]):
    old_map = {i.get("ifname"): i for i in old}
    new_map = {i.get("ifname"): i for i in new}
    for name in sorted(set(old_map) | set(new_map)):
        o, n = old_map.get(name), new_map.get(name)
        if o is None:
            lines.append(f"  + Network interface added:   {name}  ({n.get('link_type','')}  {n.get('address','')})")
        elif n is None:
            lines.append(f"  - Network interface removed: {name}")
        elif o != n:
            lines.append(f"  ~ Network interface changed: {name}  {o.get('address','')} → {n.get('address','')}")


def _diff_block(old: dict, new: dict, lines: list[str]):
    def flatten(blk, prefix=""):
        result = {}
        for dev in blk.get("blockdevices", []):
            name = prefix + dev.get("name", "?")
            result[name] = f"{dev.get('size','?')}  {dev.get('type','?')}  {dev.get('model','').strip()}  {dev.get('tran','')}"
            if dev.get("children"):
                result.update(flatten({"blockdevices": dev["children"]}, name + "/"))
        return result

    _diff_dict("Block device", flatten(old), flatten(new), lines)


def diff_snapshots(old: dict, new: dict) -> list[str]:
    lines = []

    # Kernel
    if old.get("kernel") != new.get("kernel"):
        lines.append(f"  ~ Kernel:  {old.get('kernel')}  →  {new.get('kernel')}")

    # CPU
    _diff_dict("CPU", old.get("cpu", {}), new.get("cpu", {}), lines)

    # Memory
    _diff_dict("Memory", old.get("memory", {}), new.get("memory", {}), lines)

    # PCI
    _diff_sorted_list("PCI device", old.get("pci_devices", []), new.get("pci_devices", []), lines)

    # Block
    _diff_block(old.get("block_devices", {}), new.get("block_devices", {}), lines)

    # Network
    _diff_iface_list(old.get("network_interfaces", []), new.get("network_interfaces", []), lines)

    # DMI / firmware
    _diff_dict("Firmware/DMI", old.get("dmi", {}), new.get("dmi", {}), lines)

    return lines


# ---------------------------------------------------------------------------
# Login-time contention summary
# ---------------------------------------------------------------------------

_SKIP_COMMS = frozenset([
    "sshd", "login", "init", "systemd", "dbus-daemon", "agetty",
    "cron", "rsyslogd", "NetworkManager", "polkitd",
])
_SHELL_COMMS = frozenset(["bash", "sh", "zsh", "fish", "csh", "tcsh", "dash", "ksh"])
_TRIVIAL_COMMS = frozenset([
    "ps", "grep", "awk", "sed", "cat", "ls", "man", "less", "more",
    "top", "htop", "vim", "nano", "emacs", "tmux", "screen",
    "ssh", "sftp", "scp", "tail", "head", "watch",
])


def _fmt_mem(kb: int) -> str:
    if kb >= 1024 * 1024:
        return f"{kb / 1024 / 1024:.1f}GB"
    elif kb >= 1024:
        return f"{kb / 1024:.0f}MB"
    return f"{kb}KB"


def _fmt_elapsed(s: int) -> str:
    if s < 60:
        return f"{s}s"
    elif s < 3600:
        return f"{s // 60}m"
    elif s < 86400:
        return f"{s // 3600}h{(s % 3600) // 60:02d}m"
    return f"{s // 86400}d{(s % 86400) // 3600:02d}h"


def _get_load_pct() -> tuple[float, int]:
    try:
        load1 = float(open("/proc/loadavg").read().split()[0])
    except Exception:
        load1 = 0.0
    ncpu = os.cpu_count() or 1
    return load1, ncpu


def _get_mem_pct() -> tuple[int, int]:
    """Return (used_kb, total_kb)."""
    try:
        mi: dict[str, int] = {}
        for line in Path("/proc/meminfo").read_text().splitlines():
            k, _, v = line.partition(":")
            k = k.strip()
            if k in ("MemTotal", "MemAvailable"):
                mi[k] = int(v.strip().split()[0])
        total = mi.get("MemTotal", 0)
        used = total - mi.get("MemAvailable", 0)
        return used, total
    except Exception:
        return 0, 0


def print_login_contention_summary() -> None:
    """Print a brief server-load and active-workload summary at every login."""
    hostname = socket.gethostname()
    load1, ncpu = _get_load_pct()
    load_pct = load1 / ncpu * 100
    used_kb, total_kb = _get_mem_pct()
    mem_pct = used_kb / total_kb * 100 if total_kb else 0

    load_lv = "HIGH" if load_pct >= 80 else "MODERATE" if load_pct >= 50 else "LOW"
    mem_lv  = "HIGH" if mem_pct  >= 85 else "MODERATE" if mem_pct  >= 60 else "LOW"

    # GPU (optional, skip if not available)
    gpu_line = ""
    try:
        out = subprocess.run(
            ["nvidia-smi", "--query-gpu=utilization.gpu,memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5,
        ).stdout.strip()
        if out:
            totals = [l.split(",") for l in out.splitlines() if l.strip()]
            utils = []
            for cols in totals:
                if len(cols) >= 1:
                    try:
                        utils.append(int(cols[0].strip()))
                    except ValueError:
                        pass
            if utils:
                max_u = max(utils)
                gpu_lv = "HIGH" if max_u >= 70 else "MODERATE" if max_u >= 30 else "LOW"
                gpu_line = f"  GPU:{gpu_lv}({max_u}%)"
    except Exception:
        pass

    # Collect who's running what — limit to currently logged-in users
    logged_in: set[str] = set()
    try:
        who_out = subprocess.run(["who"], capture_output=True, text=True).stdout
        for line in who_out.splitlines():
            parts = line.split()
            if parts:
                logged_in.add(parts[0])
    except Exception:
        pass

    user_summary: dict[str, dict] = {}  # user -> {cpu, mem_kb, top_proc}
    if logged_in:
        try:
            ps_out = subprocess.run(
                ["ps", "-e", "-o", "user:32,pid,pcpu,rss,etimes,comm,args", "--no-headers"],
                capture_output=True, text=True, timeout=15,
            ).stdout

            raw: dict[str, list] = defaultdict(list)
            for line in ps_out.splitlines():
                parts = line.split(None, 6)
                if len(parts) < 6:
                    continue
                user = parts[0]
                if user not in logged_in:
                    continue
                try:
                    cpu      = float(parts[2])
                    mem_kb   = int(parts[3])
                    elapsed  = int(parts[4])
                    comm     = parts[5]
                    args     = (parts[6] if len(parts) > 6 else comm).strip()
                except (ValueError, IndexError):
                    continue

                if comm in _SKIP_COMMS:
                    continue
                if (comm in _SHELL_COMMS or comm in _TRIVIAL_COMMS) and cpu < 1.0 and mem_kb < 100 * 1024:
                    continue
                if cpu >= 5.0 or mem_kb >= 256 * 1024 or elapsed >= 600:
                    raw[user].append((cpu, mem_kb, elapsed, comm, args))

            for u, procs in raw.items():
                procs.sort(reverse=True)
                top = procs[0]
                user_summary[u] = {
                    "cpu":    sum(p[0] for p in procs),
                    "mem_kb": sum(p[1] for p in procs),
                    "top_comm": top[3],
                    "top_args": top[4],
                    "top_elapsed": top[2],
                }
        except Exception:
            pass

    # Print
    print()
    print("=" * 68)
    print(f"  SERVER STATUS — {hostname}")
    print("=" * 68)
    print(
        f"  Load   : {load1:.1f} / {ncpu} CPUs  [{load_lv}]  ({load_pct:.0f}% utilization)"
    )
    print(
        f"  Memory : {_fmt_mem(used_kb)} / {_fmt_mem(total_kb)}"
        f"  [{mem_lv}]  ({mem_pct:.0f}% used){gpu_line}"
    )

    if user_summary:
        print()
        print("  ACTIVE WORKLOADS:")
        for user in sorted(user_summary):
            info = user_summary[user]
            cmd_disp = info["top_args"][:44] + "..." if len(info["top_args"]) > 44 else info["top_args"]
            print(
                f"    {user:<20} CPU:{info['cpu']:5.1f}%  MEM:{_fmt_mem(info['mem_kb']):<7}"
                f"  [{info['top_comm']} — up {_fmt_elapsed(info['top_elapsed'])}]  {cmd_disp}"
            )
        if load_lv in ("MODERATE", "HIGH") or mem_lv in ("MODERATE", "HIGH"):
            print()
            print("  Note: server is under load — consider checking with 'show-contention'")
    else:
        print()
        print("  No significant workloads running.")

    print("=" * 68)
    print()


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]

    # --summary-only: contention block only, exit (used by /etc/update-motd.d/)
    if "--summary-only" in args:
        print_login_contention_summary()
        return

    # --reboot-check-only: skip contention block (MOTD already showed it),
    # only print the post-reboot hardware diff if a reboot happened.
    reboot_check_only = "--reboot-check-only" in args

    username = pwd.getpwuid(os.getuid()).pw_name
    boot_time = get_last_boot_time()
    prev_login = get_previous_login_time(username)

    # Load saved snapshot from last login
    saved: dict | None = None
    if SNAPSHOT_FILE.exists():
        try:
            saved = json.loads(SNAPSHOT_FILE.read_text())
        except Exception:
            saved = None

    rebooted = False
    if boot_time and saved and saved.get("boot_time"):
        saved_boot = datetime.fromisoformat(saved["boot_time"])
        rebooted = boot_time > saved_boot

    # Collect current hardware state
    current = collect_hardware_snapshot()

    # Contention summary: show always unless MOTD already showed it
    if not reboot_check_only:
        print_login_contention_summary()

    if not rebooted:
        # Update snapshot and exit — no reboot to report
        SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)
        SNAPSHOT_FILE.write_text(json.dumps(current, indent=2))
        return

    # --- Server was rebooted since last login ---
    print()
    print("=" * 68)
    print("  SERVER WAS REBOOTED since your last login")
    print("=" * 68)
    if prev_login:
        print(f"  Your last login : {prev_login.strftime('%Y-%m-%d %H:%M')}")
    if boot_time:
        print(f"  Server rebooted : {boot_time.strftime('%Y-%m-%d %H:%M')}")
    print()

    # Prefer system-wide pre-reboot snapshot for hardware diff (written by
    # server-reboot-guardian just before shutdown) — falls back to the user's
    # last-login snapshot which may be older.
    baseline: dict | None = None
    baseline_label = ""

    if SYSTEM_PRE_REBOOT_SNAPSHOT.exists():
        try:
            baseline = json.loads(SYSTEM_PRE_REBOOT_SNAPSHOT.read_text())
            baseline_label = f"(pre-reboot snapshot from {baseline.get('recorded_at','?')[:16]})"
        except Exception:
            pass

    if baseline is None and saved:
        baseline = saved
        baseline_label = f"(your last-login snapshot from {saved.get('recorded_at','?')[:16]})"

    if baseline:
        diffs = diff_snapshots(baseline, current)
        if diffs:
            print(f"  HARDWARE / SYSTEM CHANGES {baseline_label}:")
            for line in diffs:
                print(line)
        else:
            print(f"  No hardware or kernel changes detected {baseline_label}.")
    else:
        print("  No baseline snapshot available for comparison.")
        print("  (A snapshot will be saved now for future logins.)")

    print()
    print(f"  Current kernel : {current.get('kernel', 'unknown')}")
    cpu_model = current.get("cpu", {}).get("Model name", "unknown")
    print(f"  CPU            : {cpu_model}")
    mem_total = current.get("memory", {}).get("MemTotal", "unknown")
    print(f"  Memory total   : {mem_total}")
    print("=" * 68)
    print()

    # Save updated snapshot
    SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)
    SNAPSHOT_FILE.write_text(json.dumps(current, indent=2))


if __name__ == "__main__":
    main()
